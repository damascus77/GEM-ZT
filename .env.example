# SQLite location (inside Docker: file:/data/gemzt.db)
DATABASE_URL=file:./dev.db
# zerotier-one local API base URL
ZT_CONTROLLER_URL=http://zerotier-controller:9993
# Per-request timeout (ms) for controller HTTP calls. Non-numeric/non-positive
# falls back to the default. Keeps a slow/unreachable controller from stalling
# the members-list fan-out on "Loading…".
# ZT_CONTROLLER_TIMEOUT_MS=8000
# TTL (ms) for coalescing/caching controller reads (peer list, member rosters).
# Collapses overlapping polls/tabs into one controller sweep. Kept small so data
# stays fresh; non-numeric/non-positive falls back to the default.
# ZT_CONTROLLER_CACHE_TTL_MS=3000
# Client poll intervals (ms) for the members table and presence sparkline.
# Non-numeric/non-positive falls back to the default (30000). NEXT_PUBLIC_* vars
# are baked in at build time and exposed to the browser.
# NEXT_PUBLIC_MEMBERS_REFETCH_MS=30000
# NEXT_PUBLIC_PRESENCE_REFETCH_MS=30000
# Path to the read-only mounted authtoken.secret
ZT_TOKEN_PATH=/controller/authtoken.secret
# Optional: override the token directly (skips reading ZT_TOKEN_PATH)
# ZT_AUTH_TOKEN=
# Set to true to mark the session cookie Secure (HTTPS-only). Enable when serving
# behind a TLS-terminating reverse proxy; leave unset for plain-HTTP LAN access.
# GEMZT_COOKIE_SECURE=false
# Failed-login rate limit (per username): max attempts within the window (ms).
# GEMZT_LOGIN_MAX_ATTEMPTS=5
# GEMZT_LOGIN_WINDOW_MS=900000
# Per-IP failed-login rate limit: max attempts within the window (ms).
# Complements the per-username limiter; useful when attacker sprays one password
# across many usernames from a single IP. NAT means many users share an IP, so
# this limit is intentionally higher than the per-username one.
# GEMZT_LOGIN_IP_MAX_ATTEMPTS=20
# Trust x-forwarded-for / x-real-ip for rate-limit keying. Default true (behind a
# reverse proxy that sets them). Set false if the app is exposed directly with no
# trusted proxy, so spoofed headers can't evade the per-IP login limiter.
# GEMZT_TRUST_PROXY=true
# Audit-log retention in days; rows older than this are purged opportunistically.
# GEMZT_AUDIT_RETENTION_DAYS=90
# Optional setup token. If set, POST /api/v1/setup requires this value in the
# X-Setup-Token header. Provides a persistent out-of-band gate on the first-run
# endpoint that survives process restarts (unlike the in-process rate limiter).
# Recommended when the setup endpoint is reachable from untrusted networks.
# GEMZT_SETUP_TOKEN=
# Per-IP rate limit on the public device self-authorize endpoint
# (POST /api/v1/networks/{nwid}/self-authorize): max attempts within the window (ms).
# GEMZT_SELF_AUTHORIZE_MAX_ATTEMPTS=10
# GEMZT_SELF_AUTHORIZE_WINDOW_MS=900000
